      background-color: #f7f8fc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 13px;
      color: #4a5568;
    }
    QPushButton.btn-icon:hover {
      background-color: #edf2f7;
    }
    QPushButton.btn-primary {
      background-color: #4a6cf7;
      color: white;
      border: none;
      border-radius: 10px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
    }
    QPushButton.btn-primary:hover {
      background-color: #3b5bdb;
    }
